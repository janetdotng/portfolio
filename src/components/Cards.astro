---
import Filter from '../components/Filter.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('showcase'))
  .filter((entry) => entry.slug !== 'article-template');

const normaliseGroup = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]/g, '');

const cards = entries
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
  })
  .map((entry) => ({
    id: entry.slug,
    slug: entry.slug,
    title: entry.data.title,
    cover: entry.data.cover,
    coverAlt: entry.data.coverAlt ?? entry.data.title,
    category: (entry.data.category ?? []).map(normaliseGroup),
    date: entry.data.publishDate.toISOString(),
    externalUrl: entry.data.externalUrl ?? null,
  }));

const count = cards.length;
---

<Filter count={count} />

<div class="section card">
  <div class="card-shell">
    <div class="cards-masonry my-shuffle-container" id="js-shuffle">
      <!-- IMPORTANT: sizer MUST be inside the shuffle container and MUST NOT carry grid utility classes -->
      <div class="my-sizer-element" aria-hidden="true"></div>

      {cards.map((card) => (
        <div
          class="card-item"
          data-groups={JSON.stringify(card.category)}
          data-date-created={card.date}
          data-title={card.title}
        >
          <a
            class="card-wrapper"
            href={card.externalUrl ? card.externalUrl : `/showcase/${card.slug}`}
            target={card.externalUrl ? '_blank' : '_self'}
            rel={card.externalUrl ? 'noopener noreferrer' : undefined}
          >
            <div class="card-body">
              <div class="card-figure">
                <img
                  class="card-figure__img"
                  src={card.cover}
                  alt={card.coverAlt}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>

            <div class="card-footer">
              <div class="card-name card-item__title">
                {card.title}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</div>

<script is:inline type="module">
  import '/plugins/shuffle.js';

  const Shuffle = window.Shuffle;

  class Demo {
    constructor(element) {
      this.element = element;

      this.shuffle = new Shuffle(element, {
  itemSelector: '.card-item',
  sizer: element.querySelector('.my-sizer-element'),
  percentPosition: true
});

      this.addFilterButtons();
      this.addSorting();
      this.addSearchFilter();
    }

    addFilterButtons() {
      const options = document.querySelector('.filter-options');
      if (!options) return;

      Array.from(options.children).forEach((button) => {
        button.addEventListener('click', this._handleFilterClick.bind(this), false);
      });
    }

    _handleFilterClick(evt) {
      const btn = evt.currentTarget;
      const isActive = btn.classList.contains('active');
      const group = btn.getAttribute('data-group');

      Array.from(btn.parentNode.children).forEach((child) => child.classList.remove('active'));

      let filterGroup;
      if (isActive) {
        btn.classList.remove('active');
        filterGroup = Shuffle.ALL_ITEMS;
      } else {
        btn.classList.add('active');
        filterGroup = group;
      }

      this.shuffle.filter(filterGroup);
    }

    addSorting() {
      const group = document.querySelector('.sort-options');
      if (!group) return;

      group.addEventListener('change', this._handleSortChange.bind(this));
    }

    _handleSortChange(evt) {
      const { value } = evt.target;

      const sortByDate = (el) => el.getAttribute('data-date-created');
      const sortByTitle = (el) => el.getAttribute('data-title').toLowerCase();

      if (value === 'date-created') {
        this.shuffle.sort({ reverse: true, by: sortByDate });
      } else if (value === 'title') {
        this.shuffle.sort({ by: sortByTitle });
      }
    }

    addSearchFilter() {
      const search = document.querySelector('.js-shuffle-search');
      if (!search) return;

      search.addEventListener('keyup', this._handleSearchKeyup.bind(this));
    }

    _handleSearchKeyup(evt) {
      const text = evt.target.value.toLowerCase();

      this.shuffle.filter((element, shuffle) => {
        if (shuffle.group !== Shuffle.ALL_ITEMS) {
          const groups = JSON.parse(element.getAttribute('data-groups'));
          if (groups.indexOf(shuffle.group) === -1) return false;
        }

        const title = element
          .querySelector('.card-item__title')
          .textContent
          .toLowerCase()
          .trim();

        return title.indexOf(text) !== -1;
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('js-shuffle');
    if (el) window.demo = new Demo(el);
  });
</script>