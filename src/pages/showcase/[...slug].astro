---
import DetailPostLayout from '../../layouts/DetailPostLayout.astro';
import { getCollection } from 'astro:content';
import SmartMedia from '../../components/SmartMedia.astro';
import { filterItems } from '../../data/content';

export async function getStaticPaths() {
  const entries = await getCollection('showcase');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;
const entries = await getCollection('showcase');
const entry = entries.find((e) => e.slug === slug);

if (!entry) {
  throw new Error(`Showcase entry not found: ${slug}`);
}

const { Content } = await entry.render();
const components = { img: SmartMedia };

const SMALL_WORDS = new Set(['and','or','the','of','to','in','on','for','with','a','an']);

const titleCase = (s: string) =>
  s
    .replace(/[-_]/g, ' ')
    .replace(/([a-z])([A-Z])/g, '$1 $2')
    .split(' ')
    .filter(Boolean)
    .map((w, i) => {
      const lw = w.toLowerCase();
      if (i > 0 && SMALL_WORDS.has(lw)) return lw;
      return lw.charAt(0).toUpperCase() + lw.slice(1);
    })
    .join(' ');

	const toLatinCaps = (s: string) =>
  s.replace(/[A-Za-z]+/g, (m) => m.toUpperCase());

const FILTER_MAP = Object.fromEntries(
  filterItems.map((i) => [i.dataGroup, i.content])
);
---

<DetailPostLayout ...>
  <header class="post-header">
  <a href="/showcase" class="back-link">
    <span class="arrow">←</span>
  </a>

  <h1>{toLatinCaps(entry.data.title)}</h1>

  {entry.data.intro && (
    <p class="post-intro">{entry.data.intro}</p>
  )}
</header>

  <div class="post-grid">
    <main class="post-main">
	<div class="post-content">
      <Content components={components} />
	  </div>
    </main>

    <aside class="post-aside">
      {entry.data.client && (
        <div class="meta-block">
          <h4>Client</h4>
          <p>{entry.data.client}</p>
        </div>
      )}

      {entry.data.projectDate && (
        <div class="meta-block">
          <h4>Project Date</h4>
          <p>{entry.data.projectDate}</p>
        </div>
      )}

      {entry.data.category?.length ? (
  <div class="meta-block">
    <h4>Categories</h4>
    <div class="category-row">
      {entry.data.category.map((raw) => {
        const group = raw.toLowerCase().replace(/[^a-z0-9]/g, '');
        const label = FILTER_MAP[group] ?? raw;

        return (
          <a
            class="filter-item filter-tag"
            data-group={group}
            href={`/showcase?group=${group}`}
          >
            {label}
          </a>
        );
      })}
    </div>
  </div>
) : null}
    </aside>

  </div>
</DetailPostLayout>

<style>

.post-content :global(p) {
  line-height: 1.7;
  margin: 0 0 1.1em;
}

.post-content :global(h2) {
  margin: 0.2em 0 0.9em;
  text-align: center; /* if you want */
}

.post-content :global(h3) {
  margin: 1.8em 0 0.8em;
}

.post-content :global(figure),
.post-content :global(img) {
  margin: 1.8em auto;
  display: block;
  max-width: 100%;
}

.post-grid {
  display: grid;
  grid-template-columns: 2.3fr 1fr;
  gap: 4rem;
}

.post-intro {
  font-size: 1.1rem;
  margin-bottom: 2rem;
}

.post-aside {
  margin-top: 0.6em;
  border-left: 1px solid var(--color-700);
  padding-left: 2.5rem;
  font-size: 0.9rem;
}

.back-link {
  position: absolute;
  left: 0;
  top: 24px;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;

  text-decoration: none;
  font-family: system-ui;
font-feature-settings: normal;
font-kerning: auto;
font-optical-sizing: auto;
font-size: 40px;
font-size-adjust: none;
font-stretch: 100%;
font-style: normal;
font-variant-alternates: normal;
font-variant-caps: normal;
font-variant-east-asian: normal;
font-variant-ligatures: normal;
font-variant-numeric: normal;
font-variant-position: normal;
font-variation-settings: normal;
font-weight: 400;
  color: var(--color-100);
}

.back-link .arrow {
  font-size: 1.6rem; /* shorter visual tail */
  line-height: 1;
}

.back-link:hover {
  opacity: 0.6;
}

.meta-block {
  margin-bottom: 2rem;
}

.meta-block h4 {
  font-size: 1rem;
  letter-spacing: 1px;
  margin-bottom: 1rem;
  font-weight: bold;
}

@media (max-width: 900px) {
  .post-grid {
    grid-template-columns: 1fr;
  }

  .post-aside {
    border-left: none;
    border-top: 1px solid var(--color-700);
    padding-top: 2rem;
    padding-left: 0;

    text-align: center;
    margin: 2rem auto 0;
    max-width: 520px;
  }

  .meta-block {
    margin-bottom: 2.2rem;
  }

  .category-row {
    justify-content: center;
  }

  .back-link .label {
    display: none; /* arrow only */
  }

  .back-link {
    left: 0;
  top: 36px;
  }
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 1.2rem;
}

/* Make category links behave like the existing filter buttons */
a.filter-item.filter-tag {
  -webkit-appearance: none;
  appearance: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
    height: var(--button-height);
border-radius: 32px;
background-color: var(--filter-bg);
padding: 10px 24px;
font-family: var(--font-body);
border: var(--filter-border);
line-height: 1;
letter-spacing: 0.25px;
color: var(--filter-color);
text-align: center;
cursor: pointer;
transition: all 0.35s cubic-bezier(0.075,0.82,0.165,1);
    font-size: var(--text-base);
    white-space: nowrap;
  font: inherit;
  --filter-bg: #fff;
--filter-color: #101010;
--filter-border: 1px solid #d0d0d0;
}

/* If your button style relies on :hover/:active */
a.filter-item.filter-tag:hover { text-decoration: none; }
</style>